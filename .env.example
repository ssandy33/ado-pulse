# Domain & auth (used by Caddy in production)
DOMAIN=pulse.shawnjsandy.com
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Axiom logging (optional — falls back to console-only when missing)
AXIOM_API_TOKEN=
AXIOM_DATASET=ado-pulse

# Nightly scheduler (comma-separated team names)
SCHEDULED_TEAMS=
ADO_ORG=
ADO_PROJECT=
ADO_PAT=

# Admin secret for manual scheduler trigger
ADMIN_SECRET=
